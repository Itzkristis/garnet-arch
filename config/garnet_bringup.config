# garnet/parrot self-contained "bring-up" fragment
# ==================================================
# STATUS (2026-07-01): the geni console fix links, but a *full* =y build then
# link-fails on a tail of downstream infra that is =m and referenced by the
# forced-builtin drivers — e.g. IPC_LOGGING (ipc_log_*), QCOM_SOCINFO
# (socinfo_get_part_info), and the QTI UFS inline-crypto (crypto_qti_*,
# ufshcd_qti_*). Chasing these =y is a long transitive dependency tail (esp.
# IPC_LOGGING, used by dozens of drivers). The recommended path is instead
# **modules + initramfs** (build the drivers as modules and load them in order
# from a first-stage initramfs) — see handoff.md. Keep this fragment as the
# "minimal console + core platform built-in" experiment.
# A GKI kernel ships almost the entire Qualcomm platform as *modules* that
# Android loads from vendor_dlkm via a first-stage initramfs. Booting via
# Mu-Silicium UEFI (EFI stub / GRUB / systemd-boot) has no such applicator, so
# a plain Image gives NO serial console and reaches NO storage.
#
# This fragment forces the essential parrot platform stack built-in (=y) so the
# kernel can reach a serial console + UFS root on its own. Apply on top of the
# merged gki+parrot+garnet config, then `olddefconfig` and validate over serial.
# Expect to add a few dependency symbols after the first olddefconfig pass.
#
# Scope = boot-to-console + storage. Display (DSI/panel), GPU, USB gadget,
# WiFi/BT, modem and the out-of-tree techpack modules come in later passes.

# --- Console: GENI serial + QUP wrapper + earlycon ---
# NB: the downstream serial driver depends on MSM_GENI_SE (Qualcomm's downstream
# QUPv3 engine in drivers/platform/msm/), NOT the mainline QCOM_GENI_SE.
# DO NOT force QCOM_GENI_SE=y at the same time as MSM_GENI_SE=y: both define the
# same geni_se_* symbols and the link fails with "duplicate symbol geni_se_init"
# (etc). Keep the downstream one built-in for console; leave the mainline geni +
# its I2C_QCOM_GENI/SPI_QCOM_GENI as modules (bring those in later via the
# downstream I2C_MSM_GENI/SPI_MSM_GENI variants if needed).
CONFIG_MSM_GENI_SE=y
CONFIG_SERIAL_MSM_GENI=y
CONFIG_SERIAL_MSM_GENI_CONSOLE_DEFAULT_ENABLED=y
CONFIG_SERIAL_EARLYCON=y

# --- Pinctrl / TLMM + PMIC pinctrl ---
CONFIG_PINCTRL_MSM=y
CONFIG_PINCTRL_PARROT=y
CONFIG_PINCTRL_QCOM_SPMI_PMIC=y

# --- Clocks ---
CONFIG_COMMON_CLK_QCOM=y
CONFIG_QCOM_CLK_RPMH=y
CONFIG_SM_GCC_PARROT=y

# --- SoC infrastructure ---
CONFIG_QCOM_SMEM=y
CONFIG_QCOM_SMP2P=y
CONFIG_QCOM_RPMH=y
CONFIG_QCOM_COMMAND_DB=y
CONFIG_QCOM_SCM=y
CONFIG_QCOM_AOSS_QMP=y
CONFIG_QCOM_RPMHPD=y
CONFIG_QCOM_GDSC=y

# --- SPMI / PMIC + regulators ---
CONFIG_SPMI=y
CONFIG_SPMI_MSM_PMIC_ARB=y
CONFIG_MFD_SPMI_PMIC=y
CONFIG_REGULATOR=y
CONFIG_REGULATOR_QCOM_RPMH=y
CONFIG_REGULATOR_QCOM_SPMI=y

# --- Interconnect (bus scaling; drivers probe-defer without it) ---
CONFIG_INTERCONNECT=y
CONFIG_INTERCONNECT_QCOM=y
CONFIG_INTERCONNECT_QCOM_RPMH=y
CONFIG_INTERCONNECT_QCOM_BCM_VOTER=y
CONFIG_INTERCONNECT_QCOM_PARROT=y

# --- Storage: UFS host + Qualcomm glue + PHY ---
CONFIG_SCSI_UFSHCD=y
CONFIG_SCSI_UFSHCD_PLATFORM=y
CONFIG_SCSI_UFS_QCOM=y
CONFIG_PHY_QCOM_UFS=y

# --- I2C / SPI over GENI QUP (touch, sensors) ---
# Left as modules on purpose: I2C_QCOM_GENI/SPI_QCOM_GENI depend on the *mainline*
# QCOM_GENI_SE, which must stay non-builtin to avoid the geni_se_* duplicate-symbol
# clash with the downstream MSM_GENI_SE console engine above. Revisit with the
# downstream QUPv3 I2C/SPI drivers when wiring up touch/sensors.
