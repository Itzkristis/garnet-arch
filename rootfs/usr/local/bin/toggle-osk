#!/bin/sh
# Toggle the squeekboard on-screen keyboard. Bound to Volume-Up in sway.
export XDG_RUNTIME_DIR=/run/user/1000
export DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
cur=$(busctl --user get-property sm.puri.OSK0 /sm/puri/OSK0 sm.puri.OSK0 Visible 2>/dev/null | awk "{print \$2}")
[ "$cur" = "true" ] && new=false || new=true
busctl --user call sm.puri.OSK0 /sm/puri/OSK0 sm.puri.OSK0 SetVisible b $new
